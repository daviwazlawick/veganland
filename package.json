{
  "name": "veganland",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:novaqi": "EXPO_PUBLIC_BRAND=novaqi expo start",
    "web": "expo start --web",
    "web:novaqi": "EXPO_PUBLIC_BRAND=novaqi expo start --web",
    "build:android:novaqi": "eas build --platform android --profile novaqi-android",
    "build:android:veganland": "eas build --platform android --profile veganland-android",
    "build:ios:novaqi": "eas build --platform ios --profile novaqi-ios",
    "build:ios:veganland": "eas build --platform ios --profile veganland-ios",
    "submit:android:novaqi": "eas submit --platform android --profile novaqi-android",
    "submit:ios:novaqi": "eas submit --platform ios --profile novaqi-ios",
    "update:novaqi": "EXPO_PUBLIC_BRAND=novaqi eas update --branch production",
    "update:veganland": "eas update --branch production",
    "server:install": "npm install --prefix server",
    "server:start": "npm start --prefix server",
    "server:local": "DATABASE_URL= node server/src/server.js",
    "server:migrate": "npm run db:migrate --prefix server",
    "db:up": "docker compose -f server/docker-compose.yml up -d postgres",
    "db:down": "docker compose -f server/docker-compose.yml down",
    "deploy:up": "docker compose -f server/docker-compose.yml up -d --build",
    "deploy:migrate": "docker compose -f server/docker-compose.yml exec api npm run db:migrate",
    "deploy:down": "docker compose -f server/docker-compose.yml down",
    "build:web": "BRAND=veganland EXPO_PUBLIC_BRAND=veganland EXPO_PUBLIC_API_URL=https://veganland.app EXPO_PUBLIC_APP_API_KEY=$(grep APP_API_KEY server/.env | cut -d= -f2) npx expo export --platform web --clear",
    "build:deploy": "npm run build:web && cp -r dist/* /var/www/veganland/ && pm2 restart veganland-api && echo '✓ VeganLand deploy concluído'",
    "build:novaqi": "BRAND=novaqi EXPO_PUBLIC_BRAND=novaqi EXPO_PUBLIC_API_URL=https://novaqi.app EXPO_PUBLIC_APP_API_KEY=$(grep APP_API_KEY server/.env | cut -d= -f2) npx expo export --platform web --clear",
    "build:novaqi:deploy": "npm run build:novaqi && mkdir -p /var/www/novaqi && cp -r dist/* /var/www/novaqi/ && echo '✓ NovaQI deploy concluído'"
  },
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo-google-fonts/syne": "^0.4.2",
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "expo": "~54.0.33",
    "expo-updates": "~0.27.4",
    "expo-camera": "~17.0.10",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-purchases": "^10.1.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "private": true
}
