# VeganLand - Environment Configuration Template
#
# 1. Copie este arquivo para .env
# 2. Cole sua chave da API abaixo
# 3. Nunca commite o arquivo .env em git
#
# API central do VeganLand. Em produção, use a URL do seu servidor.
EXPO_PUBLIC_API_URL=https://sua-api.example.com

# Opcional: mesmo valor de APP_API_KEY configurado no backend.
EXPO_PUBLIC_APP_API_KEY=change-this-shared-secret
